{
  "manifest_version": 3,
  "name": "Braze Localization Assistant Debug",
  "version": "0.0.0",
  "description": "Read-only debug overlay for extracting page content and calling the local Braze localization backend.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Braze Localization Assistant Debug",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "permissions": ["storage", "contextMenus"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.braze.com/*", "*://*.appboy.com/*", "*://*.braze.eu/*"],
      "all_frames": true,
      "match_about_blank": true,
      "js": [
        "dist/contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dist/monacoPageBridge.js",
        "assets/icon-16.png",
        "assets/icon-32.png",
        "assets/icon-48.png",
        "assets/icon-128.png"
      ],
      "matches": ["*://*.braze.com/*", "*://*.appboy.com/*", "*://*.braze.eu/*"]
    }
  ]
}
